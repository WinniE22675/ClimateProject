# Database — must match POSTGRES_* values in root .env
DATABASE_URL=postgresql://climate_user:your_password@db:5432/climate_db

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Analyst registration code
ADMIN_CODE=your-admin-code-here